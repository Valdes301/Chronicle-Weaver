# Chiave API per la generazione di contenuti creativi (storie, sessioni)
GEMINI_API_KEY_STORY="LA_TUA_CHIAVE_API_QUI"

# Chiave API per i task analitici (riassunti)
GEMINI_API_KEY_SUMMARY="LA_TUA_CHIAVE_API_QUI"

# URL del database. Usato da Prisma per connettersi al database SQLite.
# Per lo sviluppo locale, questo punta a un file nella cartella 'data'.
DATABASE_URL="file:./data/dev.db"
